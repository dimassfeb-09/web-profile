# JWT Secret for authentication (must be at least 32 characters in production)
JWT_SECRET=your-development-jwt-secret-min-32-chars

# PostgreSQL Database URL
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Google Analytics 4 Client-Side Tracking ID
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Analytics 4 Server-Side Property ID (numeric)
GA_PROPERTY_ID=123456789

# Google Service Account Credentials JSON (Single-line JSON string)
GA_SERVICE_ACCOUNT_CREDENTIALS='{"type": "service_account", "project_id": "...", "private_key_id": "...", "private_key": "-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n", "client_email": "...", ...}'
